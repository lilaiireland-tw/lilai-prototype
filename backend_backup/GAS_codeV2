// 主要進入點 (API 入口)
// ══════════════════════════════════════════════
function doPost(e) {
  try {
    const rawData = JSON.parse(e.postData.contents);

    // 1. 基本防呆驗證
    if (!rawData.name || !rawData.email || !rawData.ans) {
      return responseJSON({ error: "資料不完整，請重新確認。" });
    }
    else if (rawData.honeypot) {
      return responseJSON({ error: "拒絕存取" });
    }
    const userEmail = rawData.email.trim().toLowerCase();

    // ── 🛡️ 宣告快取服務 (必須放在最前面) ──
    const cache = CacheService.getScriptCache();

    // ── 🛡️ 防禦一：檢查裝置是否在 300 秒冷卻期內 ──
    const deviceId = rawData.deviceId;
    if (!deviceId) {
      return responseJSON({ error: "系統環境異常，請更換瀏覽器後再試。" }); 
    }
    const deviceCacheKey = 'cooldown_' + deviceId;
    
    // 如果快取裡有這個裝置 ID，直接擋下
    if (cache.get(deviceCacheKey)) {
      return responseJSON({ error: "您的裝置請求過於頻繁，請等待 5 分鐘後再試！" });
    }

    // ── 🛡️ 防禦二：檢查此 Email 是否已經填寫過 ──
    const ss = SpreadsheetApp.openById(SHEET_ID);
    let sheet = ss.getSheetByName('Leads');

    if (sheet) {
      const emailFound = sheet.getRange("C:C").createTextFinder(userEmail).matchEntireCell(true).findNext();
      if (emailFound) {
        return responseJSON({ error: "這個 Email 已經做過診斷囉！請去信箱查看你的專屬報告。" });
      }
    }

    // ── 🛡️ 通過所有防禦，將此裝置鎖定 300 秒 ──
    cache.put(deviceCacheKey, 'locked', 300);

    // 2. 商業邏輯：根據答案計算卡關點
    const ans = rawData.ans;
    const q2 = Array.isArray(ans.q2) ? ans.q2 : [];
    const list = [];

    if (q2.some(a => a.includes('預算'))) list.push('budget');
    if (q2.some(a => a.includes('學校太多'))) list.push('comparison');
    if (q2.some(a => a.includes('適不適合'))) list.push('direction');
    if (q2.some(a => a.includes('相信'))) list.push('trust');
    if (q2.some(a => a.includes('英文'))) list.push('reality');
    if (q2.some(a => a.includes('工作機會'))) list.push('reality');
    if (q2.some(a => a.includes('家人'))) list.push('trust');
    if (ans.q1.includes('比較語校')) list.push('comparison');
    if (ans.q1.includes('只是想出去')) list.push('direction');
    if (ans.q5.includes('反對')) list.push('trust');

    // 取前三個獨特的 Blocker
    const blockers = [...new Set(list)].slice(0, 3);
    const primary = blockers[0] || 'comparison';
    const copy = resultCopy[primary];

    // 3. 準備統整後的資料，餵給儲存與信件函式
    const processedData = {
      name: rawData.name,
      email: rawData.email,
      ig: rawData.ig,
      line: rawData.line,
      contact: rawData.contact,
      q: rawData.q,
      q1: ans.q1,
      q2: q2.join('、'),
      q3: ans.q3,
      q4: ans.q4,
      q5: ans.q5,
      // 將 blocker 轉為好看的中文標籤 (給 Sheet 跟 Email 用)
      blockers: blockers.map(b => blockerMeta[b].label).join('、'),
      primaryBlocker: primary, // 傳英文 key 給 getConsultantTips 用
      blockerTitle: copy.title,
      resultAI: copy.ai,
      resultBoth: copy.both,
      resultHuman: copy.human,
      resultBody: copy.body
    };

    // 4. 執行動作：存 Google Sheets、寄信給學生、寄通知給顧問
    saveToSheet(processedData);
    sendStudentEmail(processedData);
    sendNotifyEmail(processedData);

    // 5. 準備回傳給前端顯示的 JSON
    const returnData = {
      title: copy.title,
      body: copy.body,
      badge: copy.badge,
      ai: copy.ai,
      both: copy.both,
      human: copy.human,
      pills: (blockers.length ? blockers : ['comparison']).map(b => blockerMeta[b])
    };

    return responseJSON(returnData);

  } catch (err) {
    return responseJSON({ error: err.toString() });
  }
}

