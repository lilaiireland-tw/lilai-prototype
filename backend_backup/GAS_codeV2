      '諮詢前準備好 2–3 間符合條件的語校比較表',
      '詢問她對哪個差異最在意，幫她縮小到最後 1–2 間',
      '確認是否有預算壓力，避免推薦後才發現費用超出',
    ],
    budget: [
      '先問清楚每月可動用的預算上限（不是「應該帶多少」，而是「能動用多少」）',
      '確認台灣是否有固定支出（房租、貸款等），影響出發後的財務壓力',
      '提供預算試算框架：語校費用 + 住宿 + 生活費的基本組合',
      family ? '⚠️ 家人是財務把關者，可以準備費用透明說明供參考' : '確認家人對預算的態度',
    ],
    trust: [
      '本次諮詢首要任務是建立信任，不是推薦學校',
      '主動說明哩來的服務流程和費用組成，打消「被抽成」的疑慮',
      '用真實學生案例建立信任，讓她看到具體的故事',
      family ? '⚠️ 家人有疑慮，可提供費用透明說明給家人參考' : '了解學生對資訊來源的疑慮點',
    ],
    direction: [
      '先問：「如果錢不是問題，你現在會怎麼決定？」釐清動機',
      '不要直接推薦語校，先確認出國目的是什麼',
      '幫她梳理幾個常見的出國動機讓她選，引導找到自己的理由',
      '這次諮詢目標：讓她能說出「我想去，因為___」',
    ],
    reality: [
      '說明語校分班制度，讓她知道初階程度是可以應付的',
      '提供一般英文進步曲線參考，設定合理期待',
      '分享類似程度的學生案例，幫她建立信心',
      '釐清她對工作機會和薪資的具體期待，確認是否合理',
    ],
  };

  const base = tips[primaryBlocker] || tips.comparison;
  const result = [...base];
  if (urgent && !result.some(t => t.includes('時程'))) {
    result.push('⚡ 高緊迫性：預計 3 個月內出發，需在本次諮詢內協助做出具體決定');
  }
  if (family && !result.some(t => t.includes('家人'))) {
    result.push('⚠️ 隱形利害關係人：學生提到家人因素，建議諮詢中主動詢問家人的具體疑慮');
  }
  return result;
}

