    new Date().toLocaleString('zh-TW'),
    data.name || '', data.email || '', data.ig || '',
    data.line || '', data.contact || '',
    data.q1 || '', data.q2 || '', data.q3 || '',
    data.q4 || '', data.q5 || '',
    data.primaryBlocker || '', data.blockers || '', data.q || '',
    data.blockerTitle || '', data.resultAI || '',
    data.resultBoth || '', data.resultHuman || '',
  ]);
}

// ── 顧問下一步建議（根據 Blocker 產生） ──
